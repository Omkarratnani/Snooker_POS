{
  "name": "snooker-pos",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:dev": "concurrently \"vite\" \"node server.mjs\" \"wait-on http://localhost:5001 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "server": "node server.mjs"
  },
  "build": {
    "appId": "com.snooker.pos",
    "productName": "Snooker POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server.mjs",
      "db.mjs",
      "db.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.15.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "@noble/hashes": "1.3.3"
  }
}
