import express from 'express';
import cors from 'cors';
import fs from 'fs/promises';
import path from 'path';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const app = express();
const PORT = 5001;
const DB_PATH = path.join(__dirname, 'db.json');

app.use(cors());
app.use(express.json({ limit: '50mb' }));

// Serve static files from the React dist build
app.use(express.static(path.join(__dirname, 'dist')));

// API endpoint to load state
app.get('/api/state', async (req, res) => {
  try {
    const data = await fs.readFile(DB_PATH, 'utf-8');
    res.json(JSON.parse(data));
  } catch (error) {
    if (error.code === 'ENOENT') {
      res.json(null); // Return null if file doesn't exist, frontend will use default
    } else {
      console.error("Error reading db.json:", error);
      res.status(500).json({ error: 'Failed to read database' });
    }
  }
});

// API endpoint to save state
app.post('/api/state', async (req, res) => {
  try {
    await fs.writeFile(DB_PATH, JSON.stringify(req.body, null, 2), 'utf-8');
    res.json({ success: true });
  } catch (error) {
    console.error("Error writing db.json:", error);
    res.status(500).json({ error: 'Failed to save database' });
  }
});

// SPA Fallback
app.use((req, res) => {
  res.sendFile(path.join(__dirname, 'dist', 'index.html'));
});

app.listen(PORT, () => {
  console.log(`Production server running at http://localhost:${PORT}`);
  console.log(`Database persisting to ${DB_PATH}`);
});
